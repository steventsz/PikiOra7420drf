      "name": "01 Auth",
      "item": [
        {
          "name": "Register Patient",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const suffix = Date.now();",
                  "pm.collectionVariables.set('patientUsername', `patient_${suffix}`);",
                  "pm.collectionVariables.set('patientEmail', `patient_${suffix}@example.com`);",
                  "pm.collectionVariables.set('otherPatientUsername', `other_${suffix}`);",
                  "pm.collectionVariables.set('otherPatientEmail', `other_${suffix}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register returns 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('patientToken', data.token);",
                  "pm.collectionVariables.set('patientId', data.user.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{patientUsername}}\",\n  \"email\": \"{{patientEmail}}\",\n  \"password\": \"{{patientPassword}}\",\n  \"password_confirm\": \"{{patientPassword}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "register",
                ""
              ]
            }
          }
        },
